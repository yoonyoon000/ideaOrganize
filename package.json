{
  "name": "mind-map-brainstorm-kr",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc -b && vite build && npm run build:server",
    "preview": "vite preview",
    "start": "node dist-server/index.js",
    "build:server": "tsc -p tsconfig.server.json"
  },
  "dependencies": {
    "@xyflow/react": "^12.8.5",
    "cors": "^2.8.5",
    "dagre": "^0.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "html-to-image": "^1.11.11",
    "nanoid": "^5.1.5",
    "openai": "^4.85.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/dagre": "^0.7.52",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite": "^6.2.0"
  }
}
